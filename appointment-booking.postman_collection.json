									"if (jsonData.id) {",
									"    pm.collectionVariables.set(\"doctor_id\", jsonData.id);",
									"    console.log(\"Saved doctor_id: \" + jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Dr. Gregory House\",\n    \"email\": \"house.diagnostics@example.com\",\n    \"specialization\": \"Diagnostic Medicine\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/doctors",
