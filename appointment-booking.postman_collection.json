					},
					"response": []
				},
				{
					"name": "Define Doctor Availability",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.slots && jsonData.slots.length > 0) {",
									"    pm.collectionVariables.set(\"slot_id\", jsonData.slots[0].id);",
									"    console.log(\"Saved slot_id: \" + jsonData.slots[0].id);",
									"    if (jsonData.slots.length > 1) {",
									"        pm.collectionVariables.set(\"reschedule_slot_id\", jsonData.slots[1].id);",
									"        console.log(\"Saved reschedule_slot_id: \" + jsonData.slots[1].id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"date\": \"{{tomorrow_date}}\",\n    \"start_time\": \"09:00\",\n    \"end_time\": \"11:00\",\n    \"slot_duration\": 30\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/doctors/{{doctor_id}}/availabilities",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"doctors",
								"{{doctor_id}}",
								"availabilities"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Bookings & Slots",
			"item": [
				{
					"name": "View Available Slots",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/slots/available?doctor_id={{doctor_id}}&date={{tomorrow_date}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"slots",
								"available"
							],
							"query": [
								{
									"key": "doctor_id",
									"value": "{{doctor_id}}"
								},
								{
									"key": "date",
									"value": "{{tomorrow_date}}"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Book Appointment",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.booking && jsonData.booking.booking_reference) {",
									"    pm.collectionVariables.set(\"booking_reference\", jsonData.booking.booking_reference);",
									"    console.log(\"Saved booking_reference: \" + jsonData.booking.booking_reference);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"slot_id\": {{slot_id}},\n    \"patient_name\": \"John Watson\",\n    \"patient_email\": \"watson@example.com\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/bookings",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"bookings"
							]
						}
					},
					"response": []
				},
				{
					"name": "Reschedule Appointment",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"new_slot_id\": {{reschedule_slot_id}}\n}"
						},
						"url": {
