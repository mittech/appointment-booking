							"raw": "{{base_url}}/api/bookings/{{booking_reference}}/cancel",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"bookings",
								"{{booking_reference}}",
								"cancel"
							]
						}
					},
					"response": []
